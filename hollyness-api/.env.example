# Copy this file to .env and fill in your values
# Generate SECRET_KEY with: python3 -c "import secrets; print(secrets.token_hex(64))"

DATABASE_URL=postgresql://hollynessadmin:CHANGE_THIS_PASSWORD@localhost:5432/hollynessdb
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHARACTER_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
FRONTEND_URL=https://yourdomain.com
