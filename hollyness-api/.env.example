# Copy this to .env and fill in your values:
#   cp .env.example .env && nano .env
#
# Generate SECRET_KEY:
#   python3 -c "import secrets; print(secrets.token_hex(64))"

DATABASE_URL=postgresql://hollynessadmin:CHANGE_THIS_PASSWORD@localhost:5432/hollynessdb
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHARACTER_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# No domain yet? Use your server's IP address, e.g.: http://1.2.3.4
# When you get a domain, change to: https://yourdomain.com
FRONTEND_URL=http://YOUR_SERVER_IP
